# En-têtes de sécurité — pris en compte par Netlify et Cloudflare Pages.
# (Pour Vercel, l'équivalent est dans vercel.json à la racine.)

/*
  # Empêche le site d'être affiché dans une iframe (clickjacking)
  X-Frame-Options: DENY
  # Empêche le navigateur de deviner les types MIME
  X-Content-Type-Options: nosniff
  # Ne transmet que l'origine aux sites externes
  Referrer-Policy: strict-origin-when-cross-origin
  # Désactive les API sensibles du navigateur (aucune n'est utilisée)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  # Force HTTPS pendant 1 an
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # Politique de contenu : tout vient du site lui-même.
  # NOTE : si tu configures PUBLIC_FORM_ENDPOINT (Formspree…), ajoute son domaine à connect-src.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

# Les assets fingerprintés peuvent être mis en cache très longtemps
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
