---
/**
 * Page À propos : portrait, histoire, valeurs, et le parcours complet
 * (formation + expérience) en timelines.
 */
import { Image } from 'astro:assets';
import { Rocket, Sparkles, Target, Users } from '@lucide/astro';
import portrait from '../assets/franck.jpg';
import ContactCta from '../components/sections/ContactCta.astro';
import Timeline from '../components/sections/Timeline.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { education, experiences, values } from '../data/experience';
import BaseLayout from '../layouts/BaseLayout.astro';

const lucideMap = { sparkles: Sparkles, target: Target, users: Users, rocket: Rocket };
---

<BaseLayout
	title="À propos — Franck Kiemde"
	description="Du marketing digital au développement web : le parcours de Franck Kiemde, étudiant EPITECH en recherche d'alternance."
>
	<!-- Intro + portrait -->
	<section class="mx-auto max-w-6xl px-6 pt-36 pb-10">
		<div class="grid items-start gap-14 lg:grid-cols-[1fr_0.7fr]">
			<div>
				<SectionHeading
					eyebrow="À propos"
					title="Deux mondes, un profil"
					description="J'ai passé trois ans à faire briller des produits sur le web. Maintenant, je les construis."
					class="mb-8 md:mb-10"
				/>

				<div class="space-y-5 text-base leading-relaxed text-ink-muted" data-reveal="up">
					<p>
						Mon histoire ne commence pas par une ligne de code, mais par une page web à
						référencer. Pendant mon <strong class="text-ink">Bachelor en marketing digital</strong>,
						j'ai rédigé, optimisé, intégré — et plus je travaillais autour des sites,
						plus je voulais comprendre ce qui se passait sous le capot.
					</p>
					<p>
						En 2024, j'ai rejoint <strong class="text-ink">EPITECH Montpellier</strong>, où je
						suis aujourd'hui en 1ère année de Master of Science. La pédagogie par projets m'a
						plongé directement dans le concret : e-commerce avec
						<a href="/projects/runn" class="font-medium text-accent underline underline-offset-2">Runn</a>,
						time manager avec
						<a href="/projects/coccinell" class="font-medium text-accent underline underline-offset-2">Coccinell</a>,
						et surtout <a href="/projects/saturn" class="font-medium text-accent underline underline-offset-2">Saturn</a>,
						mon réseau social temps réel avec appels vidéo WebRTC.
					</p>
					<p>
						Ce double parcours est ma force : je code en pensant à l'utilisateur final, au
						référencement et à l'image de marque.
						<strong class="text-ink">Je cherche une alternance dès septembre 2026</strong>
						(1 semaine en formation / 9 en entreprise) où cette polyvalence fera la différence.
					</p>
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-xs lg:mt-16" data-reveal="right">
				<div
					class="absolute -inset-10 -z-10"
					style="background: radial-gradient(closest-side, var(--glow), var(--glow-2) 55%, transparent 78%)"
					aria-hidden="true"
				>
				</div>
				<div class="card-premium overflow-hidden p-2" data-tilt>
					<Image
						src={portrait}
						alt="Portrait de Franck Kiemde"
						width={420}
						class="aspect-[4/5] w-full rounded-xl object-cover"
						loading="eager"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Valeurs -->
	<section class="mx-auto max-w-6xl px-6 py-16">
		<SectionHeading
			eyebrow="Valeurs"
			title="Ce qui me définit"
			align="center"
		/>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger>
			{
				values.map((value) => {
					const ValueIcon = lucideMap[value.lucide];
					return (
						<article class="card-premium p-6 text-center hover:-translate-y-1.5 hover:border-line-strong">
							<span class="mx-auto grid size-12 place-items-center rounded-2xl bg-accent-soft text-accent">
								<ValueIcon size={22} aria-hidden="true" />
							</span>
							<h3 class="font-display mt-4 text-base font-semibold text-ink">{value.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-ink-muted">{value.description}</p>
						</article>
					);
				})
			}
		</div>
	</section>

	<!-- Parcours complet -->
	<Timeline
		eyebrow="Formation"
		title="Mon évolution"
		description="De la stratégie digitale au développement : chaque étape a ajouté une corde à mon arc."
		items={education}
	/>
	<Timeline eyebrow="Expérience" title="Sur le terrain" items={experiences} />

	<ContactCta />
</BaseLayout>
