---
/** Liste des articles du blog, du plus récent au plus ancien. */
import { getCollection } from 'astro:content';
import BlogCard from '../../components/ui/BlogCard.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
	title="Blog — Franck Kiemde"
	description="Retours d'expérience d'un étudiant EPITECH : WebRTC, NestJS, Astro, reconversion du marketing vers le développement web."
>
	<section class="mx-auto max-w-6xl px-6 pt-36 pb-24">
		<SectionHeading
			eyebrow="Blog"
			title="Carnet de bord"
			description="J'écris sur ce que je construis : les problèmes rencontrés, les choix techniques et ce qu'ils m'apprennent."
		/>

		<div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
			{posts.map((post) => <BlogCard post={post} />)}
		</div>
	</section>
</BaseLayout>
