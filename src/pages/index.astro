---
/** Page d'accueil : toutes les sections s'enchaînent en racontant le parcours. */
import BlogPreview from '../components/sections/BlogPreview.astro';
import About from '../components/sections/About.astro';
import ContactCta from '../components/sections/ContactCta.astro';
import FeaturedProjects from '../components/sections/FeaturedProjects.astro';
import Hero from '../components/sections/Hero.astro';
import Skills from '../components/sections/Skills.astro';
import TechMarquee from '../components/sections/TechMarquee.astro';
import Timeline from '../components/sections/Timeline.astro';
import { education, experiences } from '../data/experience';
import { SITE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title={SITE.title}>
	<Hero />
	<TechMarquee />
	<About />
	<Skills />
	<FeaturedProjects />
	<Timeline
		id="experience"
		eyebrow="Expérience"
		title="Mon parcours professionnel"
		description="Des stages en communication et SEO qui m'ont appris à travailler pour de vrais clients, avant de plonger dans le code."
		items={experiences}
	/>
	<Timeline
		id="formation"
		eyebrow="Formation"
		title="Mes études"
		items={education}
	/>
	<BlogPreview />
	<ContactCta />
</BaseLayout>
