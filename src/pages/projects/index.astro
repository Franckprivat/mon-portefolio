---
/**
 * Page projets, organisée en deux univers :
 *  1. Applications web (projets de développement)
 *  2. Design & créations visuelles (logos, identités, campagnes)
 * Chaque section a sa grille ; le filtre par technologie agit sur les deux.
 */
import { getCollection } from 'astro:content';
import { CodeXml, Palette } from '@lucide/astro';
import ProjectCard from '../../components/ui/ProjectCard.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugify } from '../../lib/utils';

const all = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const webProjects = all.filter((p) => p.data.category === 'web');
const designProjects = all.filter((p) => p.data.category === 'design');

// Technologies uniques pour les boutons de filtre.
const allTech = [...new Set(all.flatMap((p) => p.data.tech))].sort((a, b) =>
	a.localeCompare(b, 'fr')
);

const sections = [
	{
		id: 'web',
		icon: CodeXml,
		title: 'Applications web',
		description:
			'Projets de développement fullstack menés à EPITECH : du e-commerce au temps réel.',
		projects: webProjects,
	},
	{
		id: 'design',
		icon: Palette,
		title: 'Design & créations visuelles',
		description:
			'Logos, identités de marque et campagnes créés pendant mon parcours en marketing digital.',
		projects: designProjects,
	},
];
---

<BaseLayout
	title="Projets — Franck Kiemde"
	description="Applications web fullstack (Next.js, NestJS, Symfony) et créations visuelles : tous les projets de Franck Kiemde, filtrables par technologie."
>
	<section class="mx-auto max-w-6xl px-6 pt-36 pb-24">
		<SectionHeading
			eyebrow="Projets"
			title="Tout ce que j'ai construit"
			description="Deux univers : le développement web d'un côté, le design et l'identité visuelle de l'autre. Filtrez par technologie pour explorer."
		/>

		<!-- Filtres -->
		<div
			class="mb-16 flex flex-wrap gap-2"
			data-reveal="up"
			role="group"
			aria-label="Filtrer les projets par technologie"
		>
			<button
				type="button"
				class="filter-btn glass rounded-full px-4 py-2 text-xs font-semibold text-ink transition-all duration-300 aria-pressed:border-accent/40 aria-pressed:bg-accent-soft aria-pressed:text-accent"
				data-filter="all"
				aria-pressed="true"
			>
				Tous
			</button>
			{
				allTech.map((tech) => (
					<button
						type="button"
						class="filter-btn glass rounded-full px-4 py-2 text-xs font-medium text-ink-muted transition-all duration-300 hover:text-ink aria-pressed:border-accent/40 aria-pressed:bg-accent-soft aria-pressed:text-accent"
						data-filter={slugify(tech)}
						aria-pressed="false"
					>
						{tech}
					</button>
				))
			}
		</div>

		{
			sections.map(({ id, icon: Icon, title, description, projects }, i) => (
				<section class="project-section mb-20 last:mb-0" data-section={id}>
					<div class="mb-8 flex items-start gap-4" data-reveal="up">
						<span class="grid size-12 shrink-0 place-items-center rounded-2xl bg-accent-soft text-accent">
							<Icon size={22} aria-hidden="true" />
						</span>
						<div>
							<h2 class="font-display text-2xl font-bold tracking-tight text-ink sm:text-3xl">
								{title}
							</h2>
							<p class="mt-1.5 max-w-2xl text-sm text-ink-muted">{description}</p>
						</div>
					</div>

					<div
						class="project-grid grid gap-7 sm:grid-cols-2 lg:grid-cols-3"
						data-reveal-stagger
					>
						{projects.map((project, j) => (
							<ProjectCard project={project} eager={i === 0 && j < 3} />
						))}
					</div>
				</section>
			))
		}

		<p id="projects-empty" class="hidden py-16 text-center text-ink-muted">
			Aucun projet ne correspond à ce filtre.
		</p>
	</section>
</BaseLayout>

<script>
	/**
	 * Filtre les cartes selon leur attribut data-tech (slugs séparés par des espaces).
	 * Une section entière disparaît si plus aucune de ses cartes n'est visible.
	 */
	function bindFilters(): void {
		const sections = document.querySelectorAll<HTMLElement>('.project-section');
		if (sections.length === 0) return;

		const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
		const empty = document.getElementById('projects-empty');

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));

				let totalVisible = 0;
				sections.forEach((section) => {
					let visible = 0;
					section.querySelectorAll<HTMLElement>('[data-tech]').forEach((card) => {
						const match =
							filter === 'all' || (card.dataset.tech ?? '').split(' ').includes(filter);
						card.style.display = match ? '' : 'none';
						if (match) visible++;
					});
					section.style.display = visible > 0 ? '' : 'none';
					totalVisible += visible;
				});
				empty?.classList.toggle('hidden', totalVisible > 0);
			});
		});
	}

	document.addEventListener('astro:page-load', bindFilters);
</script>
