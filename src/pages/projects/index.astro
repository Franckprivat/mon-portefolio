---
/**
 * Page projets : grille complète + filtre par technologie (client-side).
 */
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ui/ProjectCard.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugify } from '../../lib/utils';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

// Technologies uniques pour les boutons de filtre.
const allTech = [...new Set(projects.flatMap((p) => p.data.tech))].sort((a, b) =>
	a.localeCompare(b, 'fr')
);
---

<BaseLayout
	title="Projets — Franck Kiemdé"
	description="Tous mes projets : applications fullstack (Next.js, NestJS, Astro) et créations graphiques. Filtrez par technologie."
>
	<section class="mx-auto max-w-6xl px-6 pt-36 pb-24">
		<SectionHeading
			eyebrow="Projets"
			title="Tout ce que j'ai construit"
			description="Applications web, identités visuelles : chaque carte s'ouvre sur une étude de cas. Filtrez par technologie pour explorer."
		/>

		<!-- Filtres -->
		<div class="mb-10 flex flex-wrap gap-2" data-reveal="up" role="group" aria-label="Filtrer les projets par technologie">
			<button
				type="button"
				class="filter-btn glass rounded-full px-4 py-2 text-xs font-semibold text-ink transition-all duration-300 aria-pressed:border-accent/40 aria-pressed:bg-accent-soft aria-pressed:text-accent"
				data-filter="all"
				aria-pressed="true"
			>
				Tous
			</button>
			{
				allTech.map((tech) => (
					<button
						type="button"
						class="filter-btn glass rounded-full px-4 py-2 text-xs font-medium text-ink-muted transition-all duration-300 hover:text-ink aria-pressed:border-accent/40 aria-pressed:bg-accent-soft aria-pressed:text-accent"
						data-filter={slugify(tech)}
						aria-pressed="false"
					>
						{tech}
					</button>
				))
			}
		</div>

		<!-- Grille -->
		<div id="projects-grid" class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
			{projects.map((project, i) => <ProjectCard project={project} eager={i < 3} />)}
		</div>

		<p id="projects-empty" class="hidden py-16 text-center text-ink-muted">
			Aucun projet ne correspond à ce filtre.
		</p>
	</section>
</BaseLayout>

<script>
	/** Filtre les cartes selon leur attribut data-tech (slugs séparés par des espaces). */
	function bindFilters(): void {
		const grid = document.getElementById('projects-grid');
		if (!grid) return;

		const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
		const cards = grid.querySelectorAll<HTMLElement>('[data-tech]');
		const empty = document.getElementById('projects-empty');

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter ?? 'all';
				buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));

				let visible = 0;
				cards.forEach((card) => {
					const match =
						filter === 'all' || (card.dataset.tech ?? '').split(' ').includes(filter);
					card.style.display = match ? '' : 'none';
					if (match) visible++;
				});
				empty?.classList.toggle('hidden', visible > 0);
			});
		});
	}

	document.addEventListener('astro:page-load', bindFilters);
</script>
