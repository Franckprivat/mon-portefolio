---
/**
 * Section d'accueil plein écran.
 * - titre révélé mot à mot, fond en parallaxe souris (data-parallax-*)
 * - à droite : fenêtre d'éditeur de code en verre dépoli + badges flottants
 */
import { ArrowDown, ArrowRight, Mail } from '@lucide/astro';
import { CONTACT, SITE } from '../../consts';
import Button from '../ui/Button.astro';
import SocialIcon from '../ui/SocialIcon.astro';
import TechIcon from '../ui/TechIcon.astro';

const socials = [
	{ label: 'GitHub', href: CONTACT.github, brand: 'github' as const },
	{ label: 'LinkedIn', href: CONTACT.linkedin, brand: 'linkedin' as const },
	{ label: 'Email', href: `mailto:${CONTACT.email}`, Icon: Mail },
];

/** Badges technos qui flottent autour de la carte de code. */
const floating = [
	{ slug: 'nextdotjs', label: 'NextJS', class: '-top-5 -left-6', depth: 2.4, delay: '0s' },
	{ slug: 'typescript', label: 'TypeScript', class: 'top-1/4 -right-8', depth: 3, delay: '1.2s' },
	{ slug: 'nestjs', label: 'NestJS', class: '-bottom-6 left-10', depth: 2, delay: '2.1s' },
	{ slug: 'react', label: 'React', class: '-right-4 -bottom-8', depth: 3.4, delay: '0.7s' },
];
---

<section
	class="relative flex min-h-svh items-center overflow-x-clip pt-28 pb-16"
	data-parallax-scene
>
	<!-- Décor en parallaxe -->
	<div
		class="soft-glow absolute top-24 left-[8%] size-72"
		data-parallax-layer="1.5"
		aria-hidden="true"
	>
	</div>
	<div
		class="soft-glow-2 absolute right-[5%] bottom-24 size-80"
		data-parallax-layer="2.5"
		aria-hidden="true"
	>
	</div>

	<div class="mx-auto grid w-full max-w-6xl items-center gap-14 px-6 lg:grid-cols-[1.1fr_0.9fr]">
		<!-- Colonne texte -->
		<div>
			<p
				class="glass mb-6 inline-flex items-center gap-2.5 rounded-full px-4 py-2 text-xs font-medium text-ink-muted"
				data-reveal="down"
			>
				<span class="relative flex size-2" aria-hidden="true">
					<span class="absolute inline-flex size-full animate-ping rounded-full bg-emerald-400 opacity-60 motion-reduce:animate-none"></span>
					<span class="relative inline-flex size-2 rounded-full bg-emerald-400"></span>
				</span>
				Alternance dès septembre 2026 — Montpellier
			</p>

			<h1 class="font-display text-5xl font-bold tracking-tight text-ink sm:text-6xl lg:text-7xl">
				<span class="block" data-split>{SITE.name.split(' ')[0]}</span>
				<span class="text-gradient block" data-split data-split-delay="0.1">
					{SITE.name.split(' ')[1]}
				</span>
			</h1>

			<p
				class="font-display mt-4 text-xl font-medium text-ink-muted sm:text-2xl"
				data-reveal="up"
				data-reveal-delay="0.1"
			>
				{SITE.role}
			</p>

			<p
				class="mt-5 max-w-lg text-base leading-relaxed text-ink-muted"
				data-reveal="up"
				data-reveal-delay="0.15"
			>
				Étudiant en Master of Science à <strong class="text-ink">EPITECH Montpellier</strong> avec
				un parcours en marketing digital, je conçois des applications web et mobiles complètes —
				du design de l'interface à l'API. Mon terrain de jeu : TypeScript, React, NestJS et Docker.
			</p>

			<div class="mt-8 flex flex-wrap items-center gap-4" data-reveal="up" data-reveal-delay="0.2">
				<Button href="/projects">
					Voir mes projets
					<ArrowRight
						size={16}
						class="transition-transform duration-300 group-hover:translate-x-1"
						aria-hidden="true"
					/>
				</Button>
				<Button href="/contact" variant="ghost">Me contacter</Button>
			</div>

			<ul class="mt-10 flex gap-3" data-reveal="up" data-reveal-delay="0.25">
				{
					socials.map(({ label, href, Icon, brand }) => (
						<li>
							<a
								href={href}
								target={href.startsWith('http') ? '_blank' : undefined}
								rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
								class="glass grid size-11 place-items-center rounded-full text-ink-muted transition-all duration-300 hover:-translate-y-1 hover:text-accent"
								aria-label={label}
							>
								{brand ? <SocialIcon name={brand} /> : Icon && <Icon size={18} aria-hidden="true" />}
							</a>
						</li>
					))
				}
			</ul>
		</div>

		<!-- Colonne visuelle : éditeur de code -->
		<div class="relative hidden lg:block" data-reveal="zoom" data-reveal-delay="0.15">
			<!-- Anneau décoratif en rotation lente -->
			<div
				class="absolute -inset-10 -z-10 animate-spin-slow rounded-full border border-dashed border-line-strong motion-reduce:animate-none"
				aria-hidden="true"
			>
			</div>

			<div class="glass glass-blur rounded-2xl shadow-2xl shadow-black/20" data-tilt>
				<!-- Barre de fenêtre -->
				<div class="flex items-center gap-2 border-b border-line px-5 py-3.5">
					<span class="size-3 rounded-full bg-red-400/80" aria-hidden="true"></span>
					<span class="size-3 rounded-full bg-amber-400/80" aria-hidden="true"></span>
					<span class="size-3 rounded-full bg-emerald-400/80" aria-hidden="true"></span>
					<span class="ml-3 font-mono text-xs text-ink-faint">franck.ts</span>
				</div>

				<!-- Code -->
				<pre
					class="overflow-x-auto p-6 font-mono text-[13px] leading-7"
					aria-hidden="true"><code><span class="text-accent-2">const</span> <span class="text-ink">franck</span> <span class="text-ink-faint">=</span> <span class="text-ink-faint">&#123;</span>
  <span class="text-ink-muted">formation</span><span class="text-ink-faint">:</span> <span class="text-emerald-400">'EPITECH Montpellier — MSc'</span><span class="text-ink-faint">,</span>
  <span class="text-ink-muted">stack</span><span class="text-ink-faint">:</span> <span class="text-ink-faint">[</span><span class="text-emerald-400">'TypeScript'</span><span class="text-ink-faint">,</span> <span class="text-emerald-400">'NextJS'</span><span class="text-ink-faint">,</span> <span class="text-emerald-400">'NestJS'</span><span class="text-ink-faint">],</span>
  <span class="text-ink-muted">superPouvoir</span><span class="text-ink-faint">:</span> <span class="text-emerald-400">'marketing + code'</span><span class="text-ink-faint">,</span>
  <span class="text-ink-muted">alternance</span><span class="text-ink-faint">:</span> <span class="text-emerald-400">'septembre 2026'</span><span class="text-ink-faint">,</span>
<span class="text-ink-faint">&#125;;</span>
<span class="animate-pulse-soft inline-block h-4 w-2 translate-y-0.5 bg-accent" aria-hidden="true"></span></code></pre>
			</div>

			<!-- Badges flottants -->
			{
				floating.map(({ slug, label, class: pos, depth, delay }) => (
					<span
						class={`glass absolute ${pos} flex animate-float items-center gap-2 rounded-full px-3.5 py-2 text-xs font-semibold text-ink shadow-lg motion-reduce:animate-none`}
						style={`animation-delay: ${delay}`}
						data-parallax-layer={depth}
					>
						<TechIcon slug={slug} size={15} class="text-(--brand)" />
						{label}
					</span>
				))
			}
		</div>
	</div>

	<!-- Indicateur de scroll -->
	<a
		href="#apropos"
		class="absolute bottom-6 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-ink-faint transition-colors hover:text-ink md:flex"
		aria-label="Faire défiler vers la section suivante"
		data-reveal="fade"
		data-reveal-delay="0.35"
	>
		<span class="text-[10px] font-medium tracking-[0.25em] uppercase">Découvrir</span>
		<ArrowDown size={15} class="animate-bounce motion-reduce:animate-none" aria-hidden="true" />
	</a>
</section>
