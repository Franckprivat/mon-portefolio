---
/**
 * Timeline verticale animée — réutilisée pour l'expérience ET la formation.
 * Chaque étape se révèle au scroll ; la ligne est dessinée en dégradé.
 */
import type { TimelineItem } from '../../data/experience';
import Badge from '../ui/Badge.astro';
import SectionHeading from '../ui/SectionHeading.astro';

interface Props {
	id?: string;
	eyebrow: string;
	title: string;
	description?: string;
	items: TimelineItem[];
}

const { id, eyebrow, title, description, items } = Astro.props;
---

<section id={id} class="mx-auto max-w-4xl scroll-mt-24 px-6 py-24 md:py-32">
	<SectionHeading {eyebrow} {title} {description} />

	<ol class="relative space-y-12 border-l border-line-strong pl-8 md:pl-12">
		<!-- Trait dégradé superposé à la bordure -->
		<div
			class="absolute top-0 -left-px h-full w-px bg-linear-to-b from-accent via-accent-2/60 to-transparent"
			aria-hidden="true"
		>
		</div>

		{
			items.map((item) => (
				<li class="relative" data-reveal="left">
					<!-- Point sur la ligne -->
					<span
						class="absolute top-1.5 -left-[41px] grid size-5 place-items-center md:-left-[57px]"
						aria-hidden="true"
					>
						<span class="absolute size-5 rounded-full bg-accent/20" />
						<span class="size-2.5 rounded-full bg-linear-120 from-accent to-accent-2 shadow-[0_0_12px_var(--glow)]" />
					</span>

					<div class="flex flex-wrap items-center gap-x-3 gap-y-2">
						<h3 class="font-display text-lg font-semibold text-ink">{item.title}</h3>
						<Badge tone="accent">{item.type}</Badge>
					</div>

					<p class="mt-1 text-sm font-medium text-ink-muted">
						{item.organization}
						<span class="text-ink-faint"> · {item.period}</span>
					</p>

					<p class="mt-3 text-sm leading-relaxed text-ink-muted">{item.description}</p>

					{item.tasks && (
						<ul class="mt-3 space-y-1.5 text-sm text-ink-muted">
							{item.tasks.map((task) => (
								<li class="flex gap-2.5">
									<span class="mt-2 size-1 shrink-0 rounded-full bg-accent" aria-hidden="true" />
									{task}
								</li>
							))}
						</ul>
					)}

					{item.tech && (
						<div class="mt-4 flex flex-wrap gap-1.5">
							{item.tech.map((t) => (
								<Badge>{t}</Badge>
							))}
						</div>
					)}
				</li>
			))
		}
	</ol>
</section>
