---
/**
 * Petite pastille : technologies, tags, statuts.
 * `tone` : neutral (par défaut) | accent
 */
interface Props {
	tone?: 'neutral' | 'accent';
	class?: string;
}

const { tone = 'neutral', class: className = '' } = Astro.props;

const tones = {
	neutral: 'glass text-ink-muted',
	accent: 'bg-accent-soft text-accent border border-accent/25',
};
---

<span
	class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium whitespace-nowrap ${tones[tone]} ${className}`}
>
	<slot />
</span>
