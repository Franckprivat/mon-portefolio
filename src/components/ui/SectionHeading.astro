---
/**
 * En-tête de section : surtitre (eyebrow), titre révélé mot à mot, description.
 * `align` : left | center
 */
interface Props {
	eyebrow: string;
	title: string;
	description?: string;
	align?: 'left' | 'center';
	class?: string;
}

const { eyebrow, title, description, align = 'left', class: className = '' } = Astro.props;
const centered = align === 'center';
---

<div class={`mb-12 md:mb-16 ${centered ? 'text-center' : ''} ${className}`}>
	<p
		class={`mb-4 inline-flex items-center gap-2 text-xs font-semibold tracking-[0.2em] uppercase text-accent ${centered ? 'justify-center' : ''}`}
		data-reveal="fade"
	>
		<span class="h-px w-8 bg-accent" aria-hidden="true"></span>
		{eyebrow}
		{centered && <span class="h-px w-8 bg-accent" aria-hidden="true"></span>}
	</p>
	<h2
		class="font-display text-3xl font-bold tracking-tight text-ink sm:text-4xl lg:text-5xl"
		data-split
	>
		{title}
	</h2>
	{
		description && (
			<p
				class={`mt-5 max-w-2xl text-base leading-relaxed text-ink-muted md:text-lg ${centered ? 'mx-auto' : ''}`}
				data-reveal="up"
				data-reveal-delay="0.1"
			>
				{description}
			</p>
		)
	}
</div>
