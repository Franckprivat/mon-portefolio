---
/**
 * Carte d'article de blog : couverture, date, temps de lecture, tags.
 */
import { Image } from 'astro:assets';
import { CalendarDays, Clock } from '@lucide/astro';
import type { CollectionEntry } from 'astro:content';
import { formatDate, readingTime } from '../../lib/utils';
import Badge from './Badge.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, cover, tags, pubDate } = post.data;
const minutes = readingTime(post.body ?? '');
---

<article
	class="card-premium group relative flex h-full flex-col overflow-hidden hover:-translate-y-2 hover:border-line-strong"
>
	<a href={`/blog/${post.id}`} class="block overflow-hidden" tabindex="-1" aria-hidden="true">
		<Image
			src={cover}
			alt=""
			width={640}
			height={360}
			loading="lazy"
			class="aspect-video w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
		/>
	</a>

	<div class="flex grow flex-col p-6">
		<div class="flex items-center gap-4 text-xs text-ink-faint">
			<time datetime={pubDate.toISOString()} class="inline-flex items-center gap-1.5">
				<CalendarDays size={13} aria-hidden="true" />
				{formatDate(pubDate)}
			</time>
			<span class="inline-flex items-center gap-1.5">
				<Clock size={13} aria-hidden="true" />
				{minutes} min
			</span>
		</div>

		<h3 class="font-display mt-3 text-lg leading-snug font-semibold text-ink">
			<a
				href={`/blog/${post.id}`}
				class="transition-colors after:absolute after:inset-0 group-hover:text-accent"
				data-cursor
			>
				{title}
			</a>
		</h3>

		<p class="mt-2 line-clamp-3 grow text-sm leading-relaxed text-ink-muted">{description}</p>

		{
			tags.length > 0 && (
				<div class="mt-4 flex flex-wrap gap-1.5">
					{tags.map((t) => (
						<Badge>{t}</Badge>
					))}
				</div>
			)
		}
	</div>
</article>
