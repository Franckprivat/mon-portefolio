---
/**
 * Curseur personnalisé : un point précis + un anneau qui traîne.
 * Piloté par app.ts (gsap.quickTo). Rendu uniquement utile sur desktop —
 * masqué et inerte sur écran tactile.
 */
---

<div
	id="cursor-dot"
	class="pointer-events-none fixed top-0 left-0 z-[100] hidden size-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent [html.custom-cursor_&]:block"
	aria-hidden="true"
>
</div>
<div
	id="cursor-ring"
	class="pointer-events-none fixed top-0 left-0 z-[100] hidden size-9 -translate-x-1/2 -translate-y-1/2 rounded-full border border-accent/50 [html.custom-cursor_&]:block"
	aria-hidden="true"
>
</div>
