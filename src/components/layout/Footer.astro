---
/**
 * Pied de page : marquee du nom, réseaux sociaux, navigation, copyright.
 */
import { ArrowUpRight, FileText, Mail } from '@lucide/astro';
import { CONTACT, NAV_LINKS, SITE } from '../../consts';
import SocialIcon from '../ui/SocialIcon.astro';

const year = new Date().getFullYear();

const socials = [
	{ label: 'GitHub', href: CONTACT.github, brand: 'github' as const },
	{ label: 'LinkedIn', href: CONTACT.linkedin, brand: 'linkedin' as const },
	{ label: 'Email', href: `mailto:${CONTACT.email}`, Icon: Mail },
	{ label: 'CV', href: CONTACT.cv, Icon: FileText },
];
---

<footer class="relative mt-28 overflow-hidden border-t border-line">
	<!-- Marquee géant en filigrane -->
	<div class="pointer-events-none select-none py-8 opacity-[0.05]" aria-hidden="true">
		<div class="flex w-max animate-marquee gap-12 whitespace-nowrap motion-reduce:animate-none">
			{
				[0, 1].map(() => (
					<span class="font-display text-7xl font-bold tracking-tight md:text-8xl">
						Franck Kiemdé — Développeur Web —&nbsp;
					</span>
				))
			}
		</div>
	</div>

	<div class="mx-auto max-w-6xl px-6 pb-10">
		<div class="grid gap-10 md:grid-cols-3" data-reveal="up">
			<!-- Identité -->
			<div>
				<a href="/" class="font-display text-xl font-bold text-ink">
					franck<span class="text-gradient">.k</span>
				</a>
				<p class="mt-3 max-w-xs text-sm leading-relaxed text-ink-muted">
					{SITE.role} en formation à EPITECH. Disponible pour une alternance.
				</p>
			</div>

			<!-- Navigation -->
			<nav aria-label="Navigation pied de page">
				<h2 class="mb-4 text-xs font-semibold tracking-[0.2em] text-ink-faint uppercase">
					Navigation
				</h2>
				<ul class="space-y-2">
					{
						NAV_LINKS.map(({ label, href }) => (
							<li>
								<a
									href={href}
									class="group inline-flex items-center gap-1 text-sm text-ink-muted transition-colors hover:text-ink"
								>
									{label}
									<ArrowUpRight
										size={13}
										class="opacity-0 transition-all duration-300 group-hover:translate-x-0.5 group-hover:opacity-100"
										aria-hidden="true"
									/>
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<!-- Réseaux -->
			<div>
				<h2 class="mb-4 text-xs font-semibold tracking-[0.2em] text-ink-faint uppercase">
					Me suivre
				</h2>
				<ul class="flex gap-3">
					{
						socials.map(({ label, href, Icon, brand }) => (
							<li>
								<a
									href={href}
									target={href.startsWith('http') ? '_blank' : undefined}
									rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
									class="glass grid size-11 place-items-center rounded-full text-ink-muted transition-all duration-300 hover:-translate-y-1 hover:text-accent"
									aria-label={label}
									data-cursor
								>
									{brand ? <SocialIcon name={brand} /> : Icon && <Icon size={18} aria-hidden="true" />}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div
			class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-line pt-6 text-xs text-ink-faint sm:flex-row"
		>
			<p>© {year} {SITE.name}. Tous droits réservés.</p>
			<p>
				Construit avec <a
					href="https://astro.build"
					target="_blank"
					rel="noopener noreferrer"
					class="text-ink-muted underline underline-offset-2 hover:text-accent">Astro</a
				> · Animé avec GSAP
			</p>
		</div>
	</div>
</footer>
