---
/**
 * Fond animé global : halos de dégradés flottants + champ de particules léger
 * sur canvas. Fixe, derrière tout le contenu, respecte prefers-reduced-motion.
 */
---

<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
	<!-- Halos de couleur flottants -->
	<div
		class="absolute -top-40 -left-40 size-[34rem] animate-float rounded-full bg-accent/15 blur-[120px] motion-reduce:animate-none"
	>
	</div>
	<div
		class="absolute top-1/3 -right-52 size-[30rem] animate-float rounded-full bg-accent-2/12 blur-[130px] motion-reduce:animate-none"
		style="animation-duration: 9s; animation-delay: 1.5s"
	>
	</div>
	<div
		class="absolute -bottom-48 left-1/4 size-[26rem] animate-float rounded-full bg-accent/10 blur-[110px] motion-reduce:animate-none"
		style="animation-duration: 11s; animation-delay: 3s"
	>
	</div>

	<!-- Particules -->
	<canvas id="particles" class="absolute inset-0 size-full"></canvas>
</div>

<script>
	/** Champ d'étoiles dérivantes — volontairement discret et peu coûteux. */
	interface Particle {
		x: number;
		y: number;
		r: number;
		vx: number;
		vy: number;
		alpha: number;
	}

	let raf = 0;

	function startParticles(): void {
		cancelAnimationFrame(raf);

		const canvas = document.getElementById('particles') as HTMLCanvasElement | null;
		if (!canvas || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const dpr = Math.min(window.devicePixelRatio || 1, 2);
		let width = 0;
		let height = 0;

		const resize = () => {
			width = window.innerWidth;
			height = window.innerHeight;
			canvas.width = width * dpr;
			canvas.height = height * dpr;
			ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
		};
		resize();
		window.addEventListener('resize', resize, { passive: true });

		const count = Math.min(70, Math.floor(width / 22));
		const particles: Particle[] = Array.from({ length: count }, () => ({
			x: Math.random() * width,
			y: Math.random() * height,
			r: 0.6 + Math.random() * 1.6,
			vx: (Math.random() - 0.5) * 0.18,
			vy: (Math.random() - 0.5) * 0.18,
			alpha: 0.15 + Math.random() * 0.4,
		}));

		const tick = () => {
			ctx.clearRect(0, 0, width, height);
			const dark = document.documentElement.classList.contains('dark');

			for (const p of particles) {
				p.x = (p.x + p.vx + width) % width;
				p.y = (p.y + p.vy + height) % height;
				ctx.beginPath();
				ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
				ctx.fillStyle = dark
					? `rgba(196, 181, 253, ${p.alpha})`
					: `rgba(124, 92, 255, ${p.alpha * 0.6})`;
				ctx.fill();
			}
			raf = requestAnimationFrame(tick);
		};
		tick();

		// On économise le CPU quand l'onglet est masqué.
		document.addEventListener('visibilitychange', () => {
			if (document.hidden) cancelAnimationFrame(raf);
			else raf = requestAnimationFrame(tick);
		});
	}

	// Démarrage différé : les particules attendent que le thread principal
	// soit libre pour ne pas retarder l'interactivité de la page.
	function idleStart(): void {
		if ('requestIdleCallback' in window) {
			requestIdleCallback(() => startParticles(), { timeout: 2000 });
		} else {
			setTimeout(startParticles, 800);
		}
	}

	document.addEventListener('astro:page-load', idleStart);
	document.addEventListener('astro:before-swap', () => cancelAnimationFrame(raf));
</script>
